# Copy this file to .env and fill in your real values.
# Do NOT commit your .env file.

# Server port
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT signing secret for access tokens
JWT_SECRET=your_jwt_secret_here_minimum_64_chars
# JWT signing secret for refresh tokens
JWT_REFRESH_SECRET=your_refresh_secret_here_minimum_64_chars

# Primary AI provider name
AI_PROVIDER=deepseek
# Hugging Face API token used for DeepSeek model calls
HUGGINGFACE_API_KEY=your_hf_token_here
# Optional alias supported by the code
HF_API_TOKEN=
# DeepSeek model identifiers
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-R1
DEEPSEEK_CHAT_MODEL=deepseek-ai/DeepSeek-R1
DEEPSEEK_HEAVY_MODEL=deepseek-ai/DeepSeek-R1
# Hugging Face Inference API base path
DEEPSEEK_API_URL=https://api-inference.huggingface.co/models
# DeepSeek generation tuning
DEEPSEEK_TEMPERATURE=0.6
DEEPSEEK_MAX_NEW_TOKENS=1200
# DeepSeek retry behavior for transient network/upstream failures
DEEPSEEK_RETRY_COUNT=2
DEEPSEEK_RETRY_DELAY_MS=800
# Timeout for AI provider calls in milliseconds
AI_TIMEOUT_MS=45000

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Email account used for verification and reset emails
EMAIL_USER=
# App password or SMTP password for the email account
EMAIL_PASS=
