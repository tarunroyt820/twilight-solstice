# Copy this file to .env and fill in your real values.
# Do NOT commit your .env file.

# Server port
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT signing secret for access tokens
JWT_SECRET=your_jwt_secret_here_minimum_64_chars
# JWT signing secret for refresh tokens
JWT_REFRESH_SECRET=your_refresh_secret_here_minimum_64_chars

# Primary AI provider name
# Options: groq | huggingface
AI_PROVIDER=groq

# --- GROQ ---
# Groq API key
GROQ_API_KEY=your_groq_api_key_here
# Optional model overrides (set these to Llama or Qwen model IDs available in your Groq account)
GROQ_MODEL=llama-3.1-8b-instant
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_HEAVY_MODEL=llama-3.1-8b-instant
# Optional per-feature models (use these if you want Qwen for specific tasks)
GROQ_SKILLGAP_MODEL=
GROQ_ROADMAP_MODEL=
GROQ_RESUME_MODEL=
GROQ_REASONING_MODEL=

# --- HUGGING FACE (Inference Providers) ---
# Create a token at https://huggingface.co/settings/tokens
# Required when AI_PROVIDER=huggingface (or when you explicitly request provider=huggingface)
HUGGINGFACE_API_KEY=your_hf_token_here
HF_API_TOKEN=
HF_TOKEN=
# Default model IDs (you will choose these later)
HF_MODEL=
HF_CHAT_MODEL=
HF_HEAVY_MODEL=
# Skill Gap model (Hugging Face only)
HF_SKILLGAP_MODEL=Qwen/Qwen2.5-VL-72B-Instruct:ovhcloud
# Generation tuning
HF_TEMPERATURE=0.4
HF_MAX_NEW_TOKENS=512
HF_SKILLGAP_MAX_NEW_TOKENS=256
HF_RETRY_COUNT=2
HF_RETRY_DELAY_MS=800
# Timeout for AI provider calls in milliseconds
AI_TIMEOUT_MS=45000

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Email account used for verification and reset emails
EMAIL_USER=
# App password or SMTP password for the email account
EMAIL_PASS=
